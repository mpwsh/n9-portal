---
import Base from "./Base.astro";

interface Props {
  frontmatter: {
    title: string;
    description?: string;
  };
}

const { frontmatter } = Astro.props;
---

<Base
  title={`${frontmatter.title} — N9 Archive`}
  description={frontmatter.description}
  active="guides"
>
  <article class="mx-auto max-w-3xl px-6 pt-16 pb-20 md:px-10 md:pt-20 md:pb-28">
    <p class="mb-4 text-[11px] font-medium uppercase tracking-[0.28em] text-n9-500">
      Guide
    </p>

    <h1
      class="font-serif text-4xl font-normal leading-[1.1] tracking-tight text-white md:text-5xl"
      style="font-variation-settings: 'opsz' 48;"
    >
      {frontmatter.title}
    </h1>

    {frontmatter.description && (
      <p
        class="mt-5 max-w-[36rem] font-serif text-[1.0625rem] leading-[1.7] text-n9-300 md:text-[1.125rem]"
        style="font-variation-settings: 'opsz' 16;"
      >
        {frontmatter.description}
      </p>
    )}

    <hr class="my-10 border-n9-800/60" />

    <div class="prose-guide">
      <slot />
    </div>

    <hr class="mt-16 mb-6 border-n9-800/60" />

    <p class="text-sm text-n9-500">
      <a href="/guides/" class="archive-link">← Back to all guides</a>
    </p>
  </article>
</Base>

<style is:global>
  /* Hand-rolled prose styles. The body voice is humanist sans, headings are
     serif at moderate opsz so they sit naturally between the title and the
     paragraphs without competing. */
  .prose-guide {
    color: var(--color-n9-200);
    font-size: 1rem;
    line-height: 1.75;
    max-width: 36rem;
  }
  .prose-guide > * + * {
    margin-top: 1.25em;
  }
  .prose-guide h2 {
    font-family: var(--font-serif);
    font-variation-settings: 'opsz' 24;
    font-size: 1.625rem;
    font-weight: 400;
    color: white;
    letter-spacing: -0.005em;
    margin-top: 2.25em;
    margin-bottom: 0.5em;
  }
  .prose-guide h3 {
    font-family: var(--font-serif);
    font-variation-settings: 'opsz' 18;
    font-size: 1.25rem;
    font-weight: 500;
    color: white;
    margin-top: 1.75em;
    margin-bottom: 0.5em;
  }
  .prose-guide p { color: var(--color-n9-200); }
  .prose-guide ul,
  .prose-guide ol {
    padding-left: 1.5em;
    color: var(--color-n9-200);
  }
  .prose-guide ul { list-style: disc; }
  .prose-guide ol { list-style: decimal; }
  .prose-guide li { margin: 0.4em 0; }
  .prose-guide li::marker { color: var(--color-n9-500); }
  .prose-guide strong { color: white; font-weight: 600; }

  /* Inherit the global link treatment so prose links match links on every
     other page. */
  .prose-guide a {
    color: var(--color-n9-50);
    border-bottom: 1px solid var(--color-accent-soft);
    padding-bottom: 1px;
    transition: border-color 150ms ease, color 150ms ease;
    text-decoration: none;
  }
  .prose-guide a:hover {
    color: var(--color-accent);
    border-bottom-color: var(--color-accent);
  }
  .prose-guide a:visited {
    color: var(--color-n9-300);
  }
  .prose-guide a:visited:hover {
    color: var(--color-accent);
  }

  .prose-guide code {
    background: var(--color-n9-800);
    color: var(--color-n9-100);
    padding: 0.15em 0.4em;
    border-radius: 0.3em;
    font-size: 0.9em;
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
  }
  .prose-guide pre {
    background: var(--color-n9-950);
    border: 1px solid var(--color-n9-800);
    color: var(--color-n9-100);
    padding: 1em 1.25em;
    border-radius: 0.5em;
    overflow-x: auto;
    font-size: 0.875em;
    line-height: 1.6;
  }
  .prose-guide pre code {
    background: transparent;
    padding: 0;
    border-radius: 0;
    font-size: 1em;
  }
  .prose-guide blockquote {
    border-left: 2px solid var(--color-accent-soft);
    padding: 0.25em 0 0.25em 1em;
    background: transparent;
    color: var(--color-n9-300);
    font-style: italic;
  }
  .prose-guide blockquote p { color: var(--color-n9-300); }
  .prose-guide hr {
    border: 0;
    border-top: 1px solid var(--color-n9-800);
    margin: 2em 0;
  }
</style>
