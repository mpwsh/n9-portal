---
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
  /** Which nav item is active for highlighting */
  active?: "home" | "packages" | "firmware" | "design" | "manuals" | "guides" | "docs";
}

const {
  title,
  description = "An archive of the MeeGo Harmattan world for the Nokia N9.",
  active,
} = Astro.props;

const navItems = [
  { key: "packages", label: "Packages", href: "/packages" },
  { key: "firmware", label: "Firmware", href: "/firmware" },
  { key: "design", label: "Design", href: "/design" },
  { key: "manuals", label: "Manuals", href: "/manuals" },
  { key: "docs", label: "Dev docs", href: "/docs/" },
  { key: "guides", label: "Guides", href: "/guides/" },
] as const;
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'%3E%3Cstyle%3Etext%7Bfont:italic 600 70px Georgia,serif%3Bfill:%23e5e7eb%7D%3C/style%3E%3Crect width='100' height='100' rx='18' fill='%23262842'/%3E%3Ctext x='50%25' y='72' text-anchor='middle'%3En9%3C/text%3E%3C/svg%3E" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    {/* Newsreader carries the editorial voice: serif body + display via
        the optical-size axis. One family, no second download. */}
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Newsreader:opsz,ital,wght@6..72,0,400;6..72,0,500;6..72,1,400&display=swap"
    />
    <script
      is:inline
      defer
      src="https://cdn.jsdelivr.net/npm/alpinejs@3.14.x/dist/cdn.min.js"></script>
  </head>
  <body class="text-n9-100">
    <header
      x-data="{ open: false }"
      class="border-b border-n9-800/60"
    >
      <div class="mx-auto flex h-16 max-w-screen-xl items-center justify-between gap-3 px-6 md:px-10 lg:px-16">
        <a
          href="/"
          class="font-serif text-base tracking-[0.32em] text-n9-100 uppercase hover:text-white"
          style="font-variation-settings: 'opsz' 14;"
        >
          n9 archive
        </a>

        <button
          class="flex size-8 items-center justify-center rounded-md bg-n9-800 text-n9-100 md:hidden"
          @click="open = !open"
          aria-label="Toggle navigation"
        >
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="size-4">
            <path x-show="!open" d="M4 6h16M4 12h16M4 18h16"></path>
            <path x-show="open" d="M6 18L18 6M6 6l12 12"></path>
          </svg>
        </button>

        <nav class="hidden items-center gap-5 md:flex">
          {navItems.map((item) => (
            <a
              href={item.href}
              class:list={[
                "text-sm transition-colors",
                active === item.key
                  ? "text-white"
                  : "text-n9-400 hover:text-n9-100",
              ]}
            >
              {item.label}
            </a>
          ))}
        </nav>
      </div>

      <nav x-cloak x-show="open" class="grid gap-2 pb-3 md:hidden px-6">
        {navItems.map((item) => (
          <a
            href={item.href}
            class="flex h-8 items-center rounded-md bg-n9-800 px-3.5 text-xs font-medium text-n9-100"
          >
            {item.label}
          </a>
        ))}
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer class="mx-auto max-w-screen-xl px-6 py-10 md:px-10 lg:px-16">
      <div class="border-t border-n9-800/60 pt-8 text-center font-serif text-xs leading-relaxed text-n9-500 md:text-sm">
        <p>
          Made with <span aria-hidden="true" class="text-[var(--color-accent)]">♡</span><span class="sr-only">love</span> for the
          <a
            href="https://t.me/meefamily"
            rel="noopener"
            class="archive-link"
          >
            Nokia N9 community
          </a>.
        </p>
        <p class="mt-1">
          Special thanks to
          <a
            href="https://wunderwungiel.pl/"
            rel="noopener"
            class="archive-link"
          >
            WunderW
          </a>
          for keeping mirrors alive and continued contributions.
        </p>
      </div>
    </footer>
  </body>
</html>
