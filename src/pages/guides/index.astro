---
import Base from "../../layouts/Base.astro";

const modules = import.meta.glob<{
  frontmatter: { title: string; description?: string };
  url: string;
}>("./*.md", { eager: true });

const sorted = Object.values(modules)
  .map((g) => ({
    title: g.frontmatter.title ?? "Untitled",
    description: g.frontmatter.description ?? "",
    url: g.url,
  }))
  .sort((a, b) => a.title.localeCompare(b.title));
---

<Base title="Guides — N9 Archive" active="guides">
  <article class="mx-auto max-w-3xl px-6 pt-16 pb-10 md:px-10 md:pt-20">
    <p class="mb-4 text-[11px] font-medium uppercase tracking-[0.28em] text-n9-500">
      Guides
    </p>
    <h1
      class="font-serif text-4xl font-normal leading-[1.05] tracking-tight text-white md:text-5xl"
      style="font-variation-settings: 'opsz' 48;"
    >
      The small fixes that come up at fifteen.
    </h1>
    <p
      class="mt-6 max-w-[36rem] font-serif text-[1.0625rem] leading-[1.7] text-n9-300 md:text-[1.125rem]"
      style="font-variation-settings: 'opsz' 16;"
    >
      Notes for the things that don't quite work out of the box: enabling
      developer mode, flashing a brick back to life, the aegis hack,
      troubleshooting the flasher. Written down so the next person doesn't
      have to figure it out twice.
    </p>
  </article>

  <section class="mx-auto max-w-3xl px-6 pb-24 md:px-10 md:pb-32">
    <ol class="border-t border-n9-800/60">
      {sorted.map((g) => (
        <li class="border-b border-n9-800/60">
          <a
            href={g.url}
            class="group flex flex-col gap-1 py-5 transition-colors"
          >
            <h2 class="font-serif text-xl text-white group-hover:text-[var(--color-accent)] transition-colors" style="font-variation-settings: 'opsz' 22;">
              {g.title}
            </h2>
            <p class="text-sm leading-relaxed text-n9-300 md:text-[0.9375rem]">
              {g.description}
            </p>
          </a>
        </li>
      ))}
    </ol>
  </section>
</Base>
